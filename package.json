{
  "name": "coding-agent-account-manager",
  "version": "1.0.0",
  "description": "Manage multiple AI coding agent accounts, switching context based on current working directory",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "cam": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssyrell/coding-agent-account-manager.git"
  },
  "keywords": [
    "cam",
    "caam",
    "claude",
    "claude code",
    "jean-claude",
    "github copilot cli",
    "github copilot",
    "copilot",
    "openai",
    "open ai",
    "codex",
    "coding agent",
    "coding-agent-account-manager"
  ],
  "author": "Steve Syrell",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ssyrell/coding-agent-account-manager/issues"
  },
  "homepage": "https://github.com/ssyrell/coding-agent-account-manager#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cross-spawn": "^7.0.3"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
